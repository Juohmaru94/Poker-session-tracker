{
  "name": "poker-session-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first poker session tracker packaged as a Windows desktop app.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.dimitris.pokersessiontracker",
    "productName": "Poker Session Tracker",
    "directories": {
      "output": "../Poker Session Tracker Desktop"
    },
    "files": [
      "electron/**/*",
      "index.html",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "devDependencies": {
    "electron": "^37.2.1",
    "electron-builder": "^26.0.12"
  }
}
